{
	default_sni 124.221.38.59
}

124.221.38.59 {
	tls {
		issuer acme {
			dir https://acme-v02.api.letsencrypt.org/directory
			profile shortlived
		}
	}

	# Backend API / auth endpoints → auth container.
	# Both branches use handle{} so they are mutually exclusive and matched in
	# source order (a bare reverse_proxy + catch-all handle would let the SPA
	# file_server swallow API paths, because Caddy orders directives, not lines).
	@backend path /api/* /admin/* /oauth/* /health
	handle @backend {
		reverse_proxy auth:3000
	}

	# Admin dashboard SPA (static) with client-side routing fallback
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
