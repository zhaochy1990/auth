# Copy this to `.env` on the Tencent Lighthouse server (~/auth/.env) and fill in
# real values. Do NOT commit the real .env — it holds the MySQL credentials.
#
# AUTH_IMAGE_TAG is NOT set here: CI passes it on the command line when running
# remote-deploy.sh, so docker-compose interpolates the right image tag.

SERVER_HOST=0.0.0.0
SERVER_PORT=3000

STORAGE_BACKEND=mysql
# Tencent Cloud MySQL DSN
MYSQL_DSN=mysql://USER:PASSWORD@HOST:3306/auth
# Uncomment if the Tencent Cloud MySQL instance requires a custom CA:
# MYSQL_TLS_CA_PEM=

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Same-origin deployment (frontend served by Caddy on the same host), so CORS is
# not normally exercised. Kept for non-same-origin clients / safety.
CORS_ALLOWED_ORIGINS=https://124.221.38.59

STRIDE_REQUIRE_INVITE_CODE=true
GIN_MODE=release
